# Bitwarden CLI Configuration
BW_URL=https://vault.yourdomain.com
BW_EMAIL=your@email.com

# System Configuration
UID=1000
GID=1000

# HITL UI Configuration
# Docker runtime chooses a free HITL port per invocation.
# These values remain useful for shell mode or manual overrides.
HITL_HOST=127.0.0.1
HITL_PORT=1138
HITL_AUTO_OPEN=true
HITL_USE_HTTPS=true
